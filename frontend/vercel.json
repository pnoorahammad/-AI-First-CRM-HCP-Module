{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "env": {
    "VITE_API_URL": {
      "description": "Backend API URL (e.g. https://your-render-backend.onrender.com)",
      "required": true
    }
  }
}
